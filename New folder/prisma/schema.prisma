// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider      = "prisma-client-js"
  binaryTargets = ["native", "debian-openssl-3.0.x", "debian-openssl-1.1.x", "rhel-openssl-3.0.x", "windows"]
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id        Int      @id @default(autoincrement())
  email     String   @unique
  password  String
  role      Role     @default(STAFF)
  createdAt DateTime @default(now())
}

enum Role {
  ADMIN
  STAFF
}

model Excursion {
  id          Int      @id @default(autoincrement())
  title       String
  description String
  imageUrl    String?
  coverImage  String?
  videoUrl    String?
  price       Float?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model PrivateTrip {
  id          Int      @id @default(autoincrement())
  title       String
  description String
  imageUrl    String?
  price       Float?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model Resort {
  id          Int      @id @default(autoincrement())
  title       String
  description String
  imageUrl    String?
  price       Float?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model Freediving {
  id          Int      @id @default(autoincrement())
  title       String
  description String
  imageUrl    String?
  price       Float?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model Photography {
  id          Int      @id @default(autoincrement())
  title       String
  description String
  imageUrl    String?
  price       Float?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model Gallery {
  id        Int      @id @default(autoincrement())
  title     String?
  imageUrl  String
  createdAt DateTime @default(now())
}

model Reel {
  id        Int      @id @default(autoincrement())
  title     String?
  videoUrl  String
  createdAt DateTime @default(now())
}

model HeroSlider {
  id        Int      @id @default(autoincrement())
  title     String?
  videoUrl  String
  createdAt DateTime @default(now())
}

model Booking {
  id          Int      @id @default(autoincrement())
  bookingNo   String   @unique
  name        String
  email       String
  category    String   // 'excursion', 'resort', etc.
  categoryId  Int?     // Reference ID to specific item
  itemTitle   String?  // Name of the booked item
  date        DateTime
  status      BookingStatus @default(PENDING)
  paymentType String?
  isPaid      Boolean  @default(false)
  createdAt   DateTime @default(now())
}

enum BookingStatus {
  PENDING
  CONFIRMED
  CANCELLED
}

model ContactMessage {
  id        Int      @id @default(autoincrement())
  name      String
  email     String
  message   String
  createdAt DateTime @default(now())
}

model WebPushSubscription {
  id        Int      @id @default(autoincrement())
  endpoint  String   @unique
  keys      Json
  createdAt DateTime @default(now())
}
